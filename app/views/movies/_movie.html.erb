<div id="<%= dom_id movie %>">
  <p class="my-5">
    <strong class="block font-medium mb-1">Title:</strong>
    <%= movie.title %>
  </p>
  <p class="my-5">
    <strong class="block font-medium mb-1">Released on:</strong>
    <%= movie.released_on %>
  </p>
  <p class="my-5">
    <strong class="block font-medium mb-1">Trailer:</strong>
    <%= movie.trailer %>
  </p>
  <p class="my-5">
    <strong class="block font-medium mb-1">Link:</strong>
    <%= movie.link %>
  </p>
  <p class="my-5">
    <strong class="block font-medium mb-1">Earnings:</strong>
    <%= movie.earnings %>
  </p>
</div>
