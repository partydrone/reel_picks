            <%= link_to "Contests", contests_path, class: ["rounded-md px-3 py-2 text-sm font-medium", {"bg-stone-900 text-white": current_page?(controller: "contests"), "text-stone-300 hover:bg-stone-700 hover:text-white": !current_page?(controller: "contests")}] %>
