      <div class="mt-3 space-y-1 px-2">
        <a href="#" class="block rounded-md px-3 py-2 text-base font-medium text-stone-400 hover:bg-stone-700 hover:text-white" data-action="click->mobile-menu#hide">Your Profile</a>
