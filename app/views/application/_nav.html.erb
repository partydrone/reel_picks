  <!-- Mobile menu, show/hide based on menu state. -->
  <div class="hidden" id="mobile-menu" data-mobile-menu-target="menu">
    <div class="space-y-1 px-2 pb-3 pt-2 sm:px-3">
      <!-- Current: "bg-stone-900 text-white", Default: "text-stone-300 hover:bg-stone-700 hover:text-white" -->
      <%= link_to "Home", root_path, class: "block rounded-md px-3 py-2 text-base font-medium text-stone-300 hover:bg-stone-700 hover:text-white" %>
      <%= link_to "Contests", contests_path, class: ["block rounded-md px-3 py-2 text-base font-medium", {"bg-stone-900 text-white": current_page?(controller: "contests"), "text-stone-300 hover:bg-stone-700 hover:text-white": !current_page?(controller: "contests")}] %>
